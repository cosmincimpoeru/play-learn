  { "id": "ai-c2-u5", "clasa": "clasa-2", "materie": "ai-roboti", "competenta": "1.1", "tip": "alegere", "dificultate": "usor", "enunt": "DACĂ ți-e foame, ATUNCI ...?", "variante": ["Mănânci", "Dormi toată ziua", "Alergi la nesfârșit", "Nu faci nimic"], "raspunsCorect": 0, "explicatie": "Dacă ți-e foame, mănânci.", "punctaj": 1 },
