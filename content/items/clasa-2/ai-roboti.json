  { "id": "ai-c2-u9", "clasa": "clasa-2", "materie": "ai-roboti", "competenta": "2.1", "tip": "adevarat-fals", "dificultate": "usor", "enunt": "Depanarea înseamnă să găsești și să repari greșeala din pași.", "variante": ["Adevărat", "Fals"], "raspunsCorect": 0, "explicatie": "Da! Asta înseamnă depanare.", "punctaj": 1 },
