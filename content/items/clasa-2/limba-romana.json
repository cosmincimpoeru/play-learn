  { "id": "lr-c2-u5", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "3.1", "tip": "alegere", "dificultate": "usor", "enunt": "„Mura doarme pe pernă.” Ce face Mura?", "variante": ["Mănâncă", "Doarme", "Aleargă", "Cântă"], "raspunsCorect": 1, "explicatie": "Mura doarme.", "punctaj": 1 },
