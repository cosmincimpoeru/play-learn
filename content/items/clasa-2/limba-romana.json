  { "id": "lr-c2-m6", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "3.2", "tip": "alegere", "dificultate": "mediu", "enunt": "„Pisica Mura a prins un ghem de lână.” Ce a prins Mura?", "variante": ["Un șoarece", "Un ghem de lână", "O minge", "Un pește"], "raspunsCorect": 1, "explicatie": "A prins un ghem de lână.", "punctaj": 1 },
  { "id": "lr-c2-m7", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "4.2", "tip": "alegere", "dificultate": "mediu", "enunt": "Care propoziție este o întrebare?", "variante": ["Afară ninge.", "Vrei să te joci cu mine?", "Eu citesc o carte.", "Soarele strălucește."], "raspunsCorect": 1, "explicatie": "„Vrei să te joci cu mine?” este o întrebare.", "punctaj": 1 },
  { "id": "lr-c2-m8", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "3.1", "tip": "alegere", "dificultate": "mediu", "enunt": "„Toamna, frunzele se îngălbenesc și cad.” Ce se întâmplă cu frunzele?", "variante": ["Înverzesc", "Se îngălbenesc și cad", "Cresc", "Înfloresc"], "raspunsCorect": 1, "explicatie": "Se îngălbenesc și cad.", "punctaj": 1 },
  { "id": "lr-c2-m9", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "3.2", "tip": "alegere", "dificultate": "mediu", "enunt": "„Sâmbătă, familia merge la bunici la țară.” Unde merge familia?", "variante": ["La mare", "La bunici la țară", "La munte", "La școală"], "raspunsCorect": 1, "explicatie": "Merge la bunici la țară.", "punctaj": 1 },
  { "id": "lr-c2-m10", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "4.2", "tip": "alegere", "dificultate": "mediu", "enunt": "Ce semn pui la o poruncă scurtă cu bucurie: „Hai la joacă___”", "variante": ["Semnul exclamării (!)", "Semnul întrebării (?)", "Virgulă (,)", "Niciunul"], "raspunsCorect": 0, "explicatie": "O exclamație/poruncă entuziastă → „!”.", "punctaj": 1 },
