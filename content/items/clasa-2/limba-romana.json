  { "id": "lr-c2-g11", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "3.1", "tip": "alegere", "dificultate": "greu", "enunt": "Care titlu se potrivește unui text despre un copil care își ajută bunica?", "variante": ["Băiatul cel bun", "Furtuna de pe mare", "Mașina roșie", "Numerele mari"], "raspunsCorect": 0, "explicatie": "„Băiatul cel bun” se potrivește temei despre ajutor și bunătate.", "punctaj": 1 },
