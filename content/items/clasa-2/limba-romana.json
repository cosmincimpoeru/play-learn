  { "id": "lr-c2-m12", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "3.2", "tip": "alegere", "dificultate": "mediu", "enunt": "„Iarna, copiii fac un om de zăpadă în curte.” Ce fac copiii?", "variante": ["Un castel de nisip", "Un om de zăpadă", "Un zmeu", "O barcă"], "raspunsCorect": 1, "explicatie": "Fac un om de zăpadă.", "punctaj": 1 },

