  { "id": "lr-c2-u8", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "4.2", "tip": "alegere", "dificultate": "usor", "enunt": "Care propoziție este o întrebare?", "variante": ["Plouă afară.", "Unde este mingea?", "Mihai citește.", "Soarele strălucește."], "raspunsCorect": 1, "explicatie": "„Unde este mingea?” este o întrebare.", "punctaj": 1 },
  { "id": "lr-c2-u9", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "3.1", "tip": "adevarat-fals", "dificultate": "usor", "enunt": "Citirea atentă ne ajută să înțelegem textul.", "variante": ["Adevărat", "Fals"], "raspunsCorect": 0, "explicatie": "Da! Citirea atentă ajută înțelegerea.", "punctaj": 1 },
  { "id": "lr-c2-u10", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "4.2", "tip": "adevarat-fals", "dificultate": "usor", "enunt": "La sfârșitul unei întrebări punem semnul întrebării (?).", "variante": ["Adevărat", "Fals"], "raspunsCorect": 0, "explicatie": "Da! Întrebările se termină cu „?”.", "punctaj": 1 },
