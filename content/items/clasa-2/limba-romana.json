  { "id": "lr-c2-m2", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "3.2", "tip": "alegere", "dificultate": "mediu", "enunt": "„Dimineața, Tudor merge la școală cu autobuzul.” Cu ce merge?", "variante": ["Cu bicicleta", "Cu autobuzul", "Pe jos", "Cu trenul"], "raspunsCorect": 1, "explicatie": "Cu autobuzul.", "punctaj": 1 },
  { "id": "lr-c2-m3", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "4.2", "tip": "alegere", "dificultate": "mediu", "enunt": "Ce semn pui: „Ce frumos este afară___” (exclamație de bucurie)", "variante": ["Semnul exclamării (!)", "Punct (.)", "Virgulă (,)", "Niciunul"], "raspunsCorect": 0, "explicatie": "O exclamație se termină cu „!”.", "punctaj": 1 },
  { "id": "lr-c2-m4", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "3.1", "tip": "alegere", "dificultate": "mediu", "enunt": "„Mihai a primit o carte de la bunici și s-a bucurat.” Ce a primit Mihai?", "variante": ["O minge", "O carte", "Un balon", "Un tren"], "raspunsCorect": 1, "explicatie": "A primit o carte.", "punctaj": 1 },
