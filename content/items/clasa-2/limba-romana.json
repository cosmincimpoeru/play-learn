  { "id": "lr-c2-g2", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "4.2", "tip": "alegere", "dificultate": "greu", "enunt": "Care propoziție folosește GREȘIT semnul de la final?", "variante": ["Unde este cartea.", "Plouă afară.", "Mihai citește.", "Soarele strălucește."], "raspunsCorect": 0, "explicatie": "„Unde este cartea” e întrebare → trebuie „?”, nu „.”.", "punctaj": 1 },
  { "id": "lr-c2-g3", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "3.2", "tip": "alegere", "dificultate": "greu", "enunt": "„Bunica a copt pâine, iar mirosul cald a umplut casa. Toți s-au strâns la masă.” De ce s-au strâns toți la masă?", "variante": ["Pentru pâinea caldă", "Ca să doarmă", "Ca să plece", "Ca să se joace"], "raspunsCorect": 0, "explicatie": "S-au strâns pentru pâinea proaspătă și caldă.", "punctaj": 1 },
  { "id": "lr-c2-g4", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "4.2", "tip": "alegere", "dificultate": "greu", "enunt": "Câte propoziții sunt: „A plouat. Apoi a ieșit soarele.”?", "variante": ["1", "2", "3", "4"], "raspunsCorect": 1, "explicatie": "Două propoziții, despărțite de puncte.", "punctaj": 1 },
