  { "id": "lr-c2-g6", "clasa": "clasa-2", "materie": "limba-romana", "competenta": "4.2", "tip": "alegere", "dificultate": "greu", "enunt": "Ce semne lipsesc: „Ce zi frumoasă___ Mergem la parc___” (bucurie, apoi o constatare)", "variante": ["! și .", ". și ?", "? și !", ", și ,"], "raspunsCorect": 0, "explicatie": "„Ce zi frumoasă!” (exclamație) și „Mergem la parc.” (constatare).", "punctaj": 1 },
